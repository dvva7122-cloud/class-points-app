# Sao chép file này thành .env và điền giá trị thật vào
# KHÔNG bao giờ commit file .env lên git

# Port server lắng nghe (mặc định 3000)
PORT=3000

# JWT Secret - Thay bằng chuỗi ngẫu nhiên dài ít nhất 64 ký tự
# Tạo bằng lệnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-long-and-random

# Hash mật khẩu admin - Tạo bằng lệnh: npm run setup
# KHÔNG điền mật khẩu thô vào đây, chỉ điền HASH đã được tạo bởi bcrypt
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
